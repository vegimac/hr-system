                    <input class="fmf-input" id="fmAllowance2" type="month">
                </div>
                <div class="fmf-field">
                    <label class="fmf-label">Zulage 3 bis</label>
                    <input class="fmf-input" id="fmAllowance3" type="month">
                </div>
            </div>

            <div class="fmf-section">Quellensteuer (QST)</div>
            <div class="fmf-row">
                <div class="fmf-field">
                    <label class="fmf-label">QST abzugsberechtigt ab</label>
                    <input class="fmf-input" id="fmQstFrom" type="date">
