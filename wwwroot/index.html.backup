<div id="timeEntryModal">
    <div class="stamp-modal-box">
        <div class="stamp-modal-head">
            <div class="stamp-modal-title" id="timeEntryModalTitle">Stempelzeit</div>
            <button class="stamp-modal-close" onclick="closeTimeEntryModal()">✕</button>
        </div>
        <div class="stamp-modal-body">
            <div class="stamp-field">
                <label class="stamp-label" for="teDate">Datum</label>
                <input class="stamp-input" id="teDate" type="date">
            </div>
            <div class="stamp-row-2">
                <div class="stamp-field">
                    <label class="stamp-label" for="teTimeIn">Ein</label>
                    <input class="stamp-input" id="teTimeIn" type="time" onchange="updateAutoNightHours()">
                </div>
                <div class="stamp-field">
                    <label class="stamp-label" for="teTimeOut">Aus</label>
                    <input class="stamp-input" id="teTimeOut" type="time" onchange="updateAutoNightHours()">
                </div>
            </div>
            <div class="stamp-field">
                <label class="stamp-label" for="teNight">Nachtstunden (automatisch berechnet)</label>
                <input class="stamp-input" id="teNight" type="number" min="0" step="0.01" value="0" readonly style="background:#f8fafc;color:#64748b">
            </div>
            <div class="stamp-field">
                <label class="stamp-label" for="teComment">Kommentar</label>
                <input class="stamp-input" id="teComment" type="text" placeholder="z.B. vergessen zu stempeln">
            </div>
        </div>
        <div class="stamp-modal-foot">
            <button class="btn btn-outline" onclick="closeTimeEntryModal()">Abbrechen</button>
            <button class="btn btn-primary" onclick="saveTimeEntry()">Speichern</button>
        </div>
    </div>
</div>

