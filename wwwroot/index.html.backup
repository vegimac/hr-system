                <div class="fmf-field">
                    <label class="fmf-label">QST abzugsberechtigt bis</label>
                    <input class="fmf-input" id="fmQstUntil" type="date">
                </div>
            </div>
        </div>
        <div class="family-modal-foot">
            <button class="btn btn-outline" onclick="closeFamilyModal()">Abbrechen</button>
            <button class="btn btn-primary" onclick="saveFamilyMember()">Speichern</button>
