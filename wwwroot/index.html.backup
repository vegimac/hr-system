<div id="absenceModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.45);align-items:flex-start;justify-content:center;z-index:2000;overflow-y:auto;padding:40px 16px;">
    <div class="abs-modal-box">
        <div class="stamp-modal-head">
            <div class="stamp-modal-title" id="absModalTitle">Absenz erfassen</div>
            <button class="stamp-modal-close" onclick="closeAbsenceModal()">✕</button>
        </div>
        <div style="padding:24px;display:flex;flex-direction:column;gap:16px;">

            <!-- Typ -->
            <div>
                <label class="form-label">Abwesenheitstyp</label>
                <select id="absTypeSelect" class="form-control" onchange="renderAbsDayCheckboxes();calcAbsHoursPreview()">
                    <option value="KRANK">Krankheit</option>
                    <option value="UNFALL">Unfall</option>
                    <option value="SCHULUNG">Schulung / andere Absenz</option>
                    <option value="FERIEN">Ferien</option>
                    <option value="MILITAER">Militär / Zivilschutz</option>
                    <option value="FEIERTAG">Feiertag (ausbezahlt)</option>
                    <option value="NACHT_KOMP">Nacht-Kompensation (Ruhetag)</option>
                </select>
            </div>

            <!-- Zeitraum -->
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                <div>
                    <label class="form-label">Von</label>
                    <input type="date" id="absDateFrom" class="form-control" oninput="renderAbsDayCheckboxes();calcAbsHoursPreview()">
                </div>
                <div>
                    <label class="form-label">Bis</label>
                    <input type="date" id="absDateTo" class="form-control" oninput="renderAbsDayCheckboxes();calcAbsHoursPreview()">
                </div>
            </div>

            <!-- Tagesauswahl -->
            <div id="absDayCheckboxes"></div>

            <!-- Stunden-Vorschau -->
            <div class="abs-hours-preview-box">
                <span class="abs-hours-preview-title">Berechnete Stunden:</span>
                <span id="absHoursPreview" data-hours="0">–</span>
            </div>

            <!-- Bemerkung -->
            <div>
                <label class="form-label">Bemerkung</label>
                <input type="text" id="absNotes" class="form-control" placeholder="Optional">
            </div>

            <!-- Buttons -->
            <div style="display:flex;gap:10px;justify-content:flex-end;margin-top:4px;">
                <button class="btn-secondary" onclick="closeAbsenceModal()">Abbrechen</button>
                <button class="btn-primary" onclick="saveAbsence()">Speichern</button>
            </div>
        </div>
    </div>
</div>

<!-- ═══════════════ QUELLENSTEUER MODAL ═══════════════ -->
<div id="qstModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.45);z-index:3000;align-items:flex-start;justify-content:center;overflow-y:auto;padding:32px 16px;">
<div style="background:#fff;border-radius:12px;width:100%;max-width:780px;box-shadow:0 20px 60px rgba(0,0,0,0.25);margin:auto">

    <!-- Header -->
    <div style="display:flex;justify-content:space-between;align-items:center;padding:20px 24px;border-bottom:1px solid #e2e8f0">
        <div>
            <div style="font-size:16px;font-weight:700;color:#1e293b">Quellensteuer</div>
            <div id="qstModalSub" style="font-size:12px;color:#64748b;margin-top:2px"></div>
        </div>
        <button onclick="closeQstModal()" style="background:none;border:none;cursor:pointer;font-size:20px;color:#94a3b8;padding:4px 8px">✕</button>
    </div>

    <!-- Stammdaten (read-only) -->
    <div style="padding:16px 24px;background:#f8fafc;border-bottom:1px solid #e2e8f0">
        <div style="font-size:11px;font-weight:600;color:#94a3b8;letter-spacing:.05em;margin-bottom:8px">STAMMDATEN</div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:6px 24px;font-size:13px">
            <div><span style="color:#64748b">Aufenthaltskategorie:</span> <span id="qstPermitDisplay" style="font-weight:500">–</span></div>
            <div><span style="color:#64748b">Wohnort:</span> <span id="qstWohnortDisplay" style="font-weight:500">–</span></div>
            <div><span style="color:#64748b">Nationalität:</span> <span id="qstNatDisplay" style="font-weight:500">–</span></div>
            <div><span style="color:#64748b">Zivilstand:</span> <span id="qstZivilstandDisplay" style="font-weight:500">–</span></div>
        </div>
    </div>

    <!-- Verlauf-Tabs -->
    <div style="padding:12px 24px 0;border-bottom:1px solid #e2e8f0;display:flex;gap:8px;align-items:center">
        <div id="qstHistoryTabs" style="display:flex;gap:6px;flex-wrap:wrap;flex:1"></div>
        <button onclick="openQstEntry(null)" style="background:#2563eb;color:#fff;border:none;border-radius:6px;padding:5px 14px;font-size:12px;cursor:pointer;font-weight:600">+ Neu ab</button>
    </div>

    <!-- Formular -->
    <div style="padding:20px 24px;display:flex;flex-direction:column;gap:0" id="qstFormWrap">

        <!-- Gültigkeit -->
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px">
            <div>
                <label style="font-size:12px;font-weight:600;color:#374151;display:block;margin-bottom:4px">Gültig ab *</label>
                <input type="date" id="qstValidFrom" style="width:100%;border:1px solid #d1d5db;border-radius:6px;padding:7px 10px;font-size:13px">
            </div>
            <div>
                <label style="font-size:12px;font-weight:600;color:#374151;display:block;margin-bottom:4px">Gültig bis</label>
                <input type="date" id="qstValidTo" style="width:100%;border:1px solid #d1d5db;border-radius:6px;padding:7px 10px;font-size:13px">
            </div>
        </div>

        <!-- Berechnung -->
        <div style="font-size:11px;font-weight:700;color:#64748b;letter-spacing:.06em;margin-bottom:10px;padding-bottom:6px;border-bottom:1px solid #f1f5f9">BERECHNUNG</div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px">
            <div>
                <label style="font-size:12px;font-weight:600;color:#374151;display:block;margin-bottom:4px">Steuerkanton</label>
                <select id="qstSteuerkanton" onchange="onQstKantonChange()" style="width:100%;border:1px solid #d1d5db;border-radius:6px;padding:7px 10px;font-size:13px">
                    <option value="">– wählen –</option>
                    <option value="AG">AG – Aargau</option>
                    <option value="AI">AI – Appenzell Innerrhoden</option>
                    <option value="AR">AR – Appenzell Ausserrhoden</option>
                    <option value="BE">BE – Bern</option>
                    <option value="BL">BL – Basel-Landschaft</option>
                    <option value="BS">BS – Basel-Stadt</option>
                    <option value="FR">FR – Freiburg</option>
                    <option value="GE">GE – Genf</option>
                    <option value="GL">GL – Glarus</option>
                    <option value="GR">GR – Graubünden</option>
                    <option value="JU">JU – Jura</option>
                    <option value="LU">LU – Luzern</option>
                    <option value="NE">NE – Neuenburg</option>
                    <option value="NW">NW – Nidwalden</option>
                    <option value="OW">OW – Obwalden</option>
                    <option value="SG">SG – St. Gallen</option>
                    <option value="SH">SH – Schaffhausen</option>
                    <option value="SO">SO – Solothurn</option>
                    <option value="SZ">SZ – Schwyz</option>
                    <option value="TG">TG – Thurgau</option>
                    <option value="TI">TI – Tessin</option>
                    <option value="UR">UR – Uri</option>
                    <option value="VD">VD – Waadt</option>
                    <option value="VS">VS – Wallis</option>
                    <option value="ZG">ZG – Zug</option>
                    <option value="ZH">ZH – Zürich</option>
                </select>
            </div>
            <div>
                <label style="font-size:12px;font-weight:600;color:#374151;display:block;margin-bottom:4px">QST-Gemeinde</label>
                <div style="display:flex;gap:6px">
                    <input type="text" id="qstGemeinde" placeholder="Gemeindename" style="flex:1;border:1px solid #d1d5db;border-radius:6px;padding:7px 10px;font-size:13px">
                    <input type="number" id="qstGemeindeBfs" placeholder="BFS-Nr" style="width:80px;border:1px solid #d1d5db;border-radius:6px;padding:7px 8px;font-size:13px">
                </div>
            </div>
            <div>
                <label style="font-size:12px;font-weight:600;color:#374151;display:block;margin-bottom:4px">Tarif</label>
                <select id="qstTarifCode" onchange="onQstTarifChange()" style="width:100%;border:1px solid #d1d5db;border-radius:6px;padding:7px 10px;font-size:13px">
                    <option value="">– wählen –</option>
                    <option value="A">A – Alleinstehend ohne Kinder</option>
                    <option value="B">B – Verheiratet, Alleinverdiener</option>
                    <option value="C">C – Verheiratet, Doppelverdiener</option>
                    <option value="D">D – Nebenerwerb</option>
                    <option value="H">H – Alleinerziehend</option>
                    <option value="L">L – Grenzgänger</option>
                    <option value="M">M – Grenzgänger verheiratet</option>
                    <option value="N">N – Grenzgänger Nebenerwerb</option>
                    <option value="P">P – Pauschale</option>
                    <option value="Q">Q – Grenzgänger alleinerziehend</option>
                </select>
            </div>
            <div>
                <label style="font-size:12px;font-weight:600;color:#374151;display:block;margin-bottom:4px">QST-Code</label>
                <input type="text" id="qstCode" placeholder="z.B. A0Y" maxlength="10" style="width:100%;border:1px solid #d1d5db;border-radius:6px;padding:7px 10px;font-size:13px;font-family:monospace">
            </div>
            <div>
                <label style="font-size:12px;font-weight:600;color:#374151;display:block;margin-bottom:4px">Anzahl Kinder</label>
                <input type="number" id="qstKinder" min="0" max="20" value="0" style="width:100%;border:1px solid #d1d5db;border-radius:6px;padding:7px 10px;font-size:13px" onchange="buildQstCode()">
            </div>
            <div style="display:flex;flex-direction:column;gap:8px;padding-top:4px">
                <label style="display:flex;align-items:center;gap:8px;font-size:13px;cursor:pointer">
                    <input type="checkbox" id="qstKirchensteuer" onchange="buildQstCode()" style="width:14px;height:14px">
                    Kirchensteuer
                </label>
                <label style="display:flex;align-items:center;gap:8px;font-size:13px;cursor:pointer">
                    <input type="checkbox" id="qstSpezielBewilligt" style="width:14px;height:14px">
                    Speziell bewilligt
                </label>
                <label style="display:flex;align-items:center;gap:8px;font-size:13px;cursor:pointer">
                    <input type="checkbox" id="qstTarifvorschlag" checked style="width:14px;height:14px">
                    Tarifvorschlag QST
                </label>
            </div>
            <div>
                <label style="font-size:12px;font-weight:600;color:#374151;display:block;margin-bottom:4px">Prozentsatz (manuell)</label>
                <input type="number" id="qstProzentsatz" step="0.01" placeholder="automatisch" style="width:100%;border:1px solid #d1d5db;border-radius:6px;padding:7px 10px;font-size:13px">
            </div>
            <div>
                <label style="font-size:12px;font-weight:600;color:#374151;display:block;margin-bottom:4px">Mindestlohn Satzbestimmung (Medianlohn)</label>
                <input type="number" id="qstMedianlohn" step="0.05" placeholder="CHF" style="width:100%;border:1px solid #d1d5db;border-radius:6px;padding:7px 10px;font-size:13px">
            </div>
        </div>

        <!-- Partner -->
        <div style="font-size:11px;font-weight:700;color:#64748b;letter-spacing:.06em;margin-bottom:10px;padding-bottom:6px;border-bottom:1px solid #f1f5f9">ZUSÄTZLICHE ANGABEN ZUM PARTNER</div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px">
            <div>
                <label style="font-size:12px;font-weight:600;color:#374151;display:block;margin-bottom:4px">Arbeitsort Kanton Partner</label>
                <select id="qstArbeitsortKanton" style="width:100%;border:1px solid #d1d5db;border-radius:6px;padding:7px 10px;font-size:13px">
                    <option value="">– kein/unbekannt –</option>
                    <option value="AG">AG</option><option value="AI">AI</option><option value="AR">AR</option>
                    <option value="BE">BE</option><option value="BL">BL</option><option value="BS">BS</option>
                    <option value="FR">FR</option><option value="GE">GE</option><option value="GL">GL</option>
                    <option value="GR">GR</option><option value="JU">JU</option><option value="LU">LU</option>
                    <option value="NE">NE</option><option value="NW">NW</option><option value="OW">OW</option>
                    <option value="SG">SG</option><option value="SH">SH</option><option value="SO">SO</option>
                    <option value="SZ">SZ</option><option value="TG">TG</option><option value="TI">TI</option>
                    <option value="UR">UR</option><option value="VD">VD</option><option value="VS">VS</option>
                    <option value="ZG">ZG</option><option value="ZH">ZH</option>
                </select>
            </div>
            <div>
                <label style="font-size:12px;font-weight:600;color:#374151;display:block;margin-bottom:4px">Partner Einkommen – Zeitraum</label>
                <div style="display:flex;gap:6px;align-items:center">
                    <input type="date" id="qstPartnerVon" style="flex:1;border:1px solid #d1d5db;border-radius:6px;padding:7px 8px;font-size:12px">
                    <span style="font-size:12px;color:#64748b">bis</span>
                    <input type="date" id="qstPartnerBis" style="flex:1;border:1px solid #d1d5db;border-radius:6px;padding:7px 8px;font-size:12px">
                </div>
            </div>
        </div>

        <!-- Zusätzliche Angaben -->
        <div style="font-size:11px;font-weight:700;color:#64748b;letter-spacing:.06em;margin-bottom:10px;padding-bottom:6px;border-bottom:1px solid #f1f5f9">ZUSÄTZLICHE ANGABEN</div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px">
            <div>
                <label style="display:flex;align-items:center;gap:8px;font-size:13px;cursor:pointer;margin-bottom:8px">
                    <input type="checkbox" id="qstWeitere" onchange="toggleQstWeitere()" style="width:14px;height:14px">
                    Weitere Beschäftigungen
                </label>
                <div id="qstWeitereFields" style="display:none;display:flex;flex-direction:column;gap:8px">
                    <div>
                        <label style="font-size:11px;color:#64748b;display:block;margin-bottom:2px">Gesamtpensum weitere AG (%)</label>
                        <input type="number" id="qstGesamtpensum" step="1" min="0" max="100" style="width:100%;border:1px solid #d1d5db;border-radius:6px;padding:6px 10px;font-size:13px">
                    </div>
                    <div>
                        <label style="font-size:11px;color:#64748b;display:block;margin-bottom:2px">Gesamteinkommen weitere AG (CHF/Mt.)</label>
                        <input type="number" id="qstGesamteinkommen" step="0.05" style="width:100%;border:1px solid #d1d5db;border-radius:6px;padding:6px 10px;font-size:13px">
                    </div>
                </div>
            </div>
            <div>
                <label style="font-size:12px;font-weight:600;color:#374151;display:block;margin-bottom:4px">Halbfamilie</label>
                <select id="qstHalbfamilie" style="width:100%;border:1px solid #d1d5db;border-radius:6px;padding:7px 10px;font-size:13px">
                    <option value="">–</option>
                    <option value="Ja">Ja</option>
                    <option value="Nein">Nein</option>
                </select>
            </div>
            <div>
                <label style="font-size:12px;font-weight:600;color:#374151;display:block;margin-bottom:4px">Wohnsitz Ausland</label>
                <input type="text" id="qstWohnsitzAusland" placeholder="Land (wenn Auslandwohnsitz)" style="width:100%;border:1px solid #d1d5db;border-radius:6px;padding:7px 10px;font-size:13px">
            </div>
            <div>
                <label style="font-size:12px;font-weight:600;color:#374151;display:block;margin-bottom:4px">Wohnsitzstaat ISO-Code</label>
                <input type="text" id="qstWohnsitzstaat" placeholder="z.B. DE, FR, IT" maxlength="5" style="width:100%;border:1px solid #d1d5db;border-radius:6px;padding:7px 10px;font-size:13px;font-family:monospace">
            </div>
            <div style="grid-column:1/-1">
                <label style="font-size:12px;font-weight:600;color:#374151;display:block;margin-bottom:4px">Adresse Ausland</label>
                <input type="text" id="qstAdresseAusland" placeholder="Strasse, PLZ, Ort" style="width:100%;border:1px solid #d1d5db;border-radius:6px;padding:7px 10px;font-size:13px">
            </div>
        </div>

        <!-- Aktionen -->
        <div style="display:flex;justify-content:flex-end;gap:10px;padding-top:8px;border-top:1px solid #f1f5f9">
            <button onclick="closeQstModal()" style="background:#f1f5f9;color:#374151;border:none;border-radius:8px;padding:9px 20px;font-size:13px;font-weight:600;cursor:pointer">Abbrechen</button>
            <button onclick="saveQstEntry()" style="background:#2563eb;color:#fff;border:none;border-radius:8px;padding:9px 22px;font-size:13px;font-weight:600;cursor:pointer">💾 Speichern</button>
        </div>
        <div id="qstSaveResult" style="margin-top:8px;font-size:12px;text-align:right"></div>
    </div>
</div>
</div>

</body>
</html>
